{
  "name": "word-chem-formula",
  "version": "1.41.0",
  "description": "Word add-in for STEM authoring: chemical & math formulas, 2D structures, units, plotting, finance, DNA/sequence tools, and patent-drafting aids.",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "dev-server": "webpack serve --mode development",
    "start": "office-addin-debugging start manifest.xml",
    "stop": "office-addin-debugging stop manifest.xml",
    "validate": "office-addin-manifest validate manifest.xml",
    "validate:compounds": "node src/lib/__tests__/validate-compounds.mjs",
    "review-sheet": "node scripts/review-sheet.js",
    "lint": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "qc": "powershell -ExecutionPolicy Bypass -File scripts/qc.ps1"
  },
  "dependencies": {
    "core-js": "^3.36.0",
    "openchemlib": "^8.0.0",
    "pptxgenjs": "^4.0.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/office-js": "^1.0.377",
    "copy-webpack-plugin": "^12.0.2",
    "html-loader": "^5.0.0",
    "html-webpack-plugin": "^5.6.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jszip": "^3.10.1",
    "office-addin-debugging": "^5.1.6",
    "office-addin-dev-certs": "^1.13.1",
    "office-addin-manifest": "^1.13.6",
    "ts-jest": "^29.1.2",
    "ts-loader": "^9.5.1",
    "typescript": "^5.4.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.0"
  }
}
